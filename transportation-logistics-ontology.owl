  <rdf:type rdf:resource="#CustomerAddress"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MaerskLine">
  <rdf:type rdf:resource="#Carrier"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#FastFreightTrucking">
  <rdf:type rdf:resource="#Carrier"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#SkyCargoAirlines">
  <rdf:type rdf:resource="#Carrier"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#AcmeElectronics">
  <rdf:type rdf:resource="#Shipper"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#BestValueRetail">
  <rdf:type rdf:resource="#Consignee"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#DriverJohnSmith">
  <rdf:type rdf:resource="#Driver"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Truck001">
  <rdf:type rdf:resource="#Truck"/>
  <operatedBy rdf:resource="#FastFreightTrucking"/>
  <drivenBy rdf:resource="#DriverJohnSmith"/>
  <capacityKg rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">20000.0</capacityKg>
  <isTemperatureControlled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTemperatureControlled>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#CargoShip_EverStar">
  <rdf:type rdf:resource="#Ship"/>
  <operatedBy rdf:resource="#MaerskLine"/>
  <capacityKg rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">5000000.0</capacityKg>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#CargoPlane_001">
  <rdf:type rdf:resource="#Aircraft"/>
  <operatedBy rdf:resource="#SkyCargoAirlines"/>
  <capacityKg rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">90000.0</capacityKg>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Route_ShanghaiToChicago">
  <rdf:type rdf:resource="#Route"/>
  <hasSegment rdf:resource="#Seg2_RoadLeg"/>
  <hasSegment rdf:resource="#Seg1_SeaLeg"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Seg1_SeaLeg">
  <rdf:type rdf:resource="#RouteSegment"/>
  <departsFrom rdf:resource="#PortOfShanghai"/>
  <arrivesAt rdf:resource="#PortOfLosAngeles"/>
  <usesMode rdf:resource="#SeaMode"/>
  <nextSegment rdf:resource="#Seg2_RoadLeg"/>
  <distanceKm rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">10500.0</distanceKm>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Seg2_RoadLeg">
  <rdf:type rdf:resource="#RouteSegment"/>
  <departsFrom rdf:resource="#PortOfLosAngeles"/>
  <arrivesAt rdf:resource="#ChicagoWarehouse"/>
  <usesMode rdf:resource="#RoadMode"/>
  <distanceKm rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">3200.0</distanceKm>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Route_AirToMilan">
  <rdf:type rdf:resource="#Route"/>
  <hasSegment rdf:resource="#Seg3_AirLeg"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Seg3_AirLeg">
  <rdf:type rdf:resource="#RouteSegment"/>
  <departsFrom rdf:resource="#OHareAirport"/>
  <arrivesAt rdf:resource="#MilanDistributionCenter"/>
  <usesMode rdf:resource="#AirMode"/>
  <distanceKm rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">7700.0</distanceKm>
</owl:NamedIndividual>

