  <rdf:type rdf:resource="#Warehouse"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#MilanDistributionCenter">
  <rdf:type rdf:resource="#DistributionCenter"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#OHareAirport">
  <rdf:type rdf:resource="#Airport"/>
</owl:NamedIndividual>

