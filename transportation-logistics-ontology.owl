<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://www.semanticweb.org/kr-project/transportation-logistics-ontology"
         xmlns="http://www.semanticweb.org/kr-project/transportation-logistics-ontology#"
         xmlns:swrl="http://www.w3.org/2003/11/swrl#">

<owl:Ontology rdf:about="http://www.semanticweb.org/kr-project/transportation-logistics-ontology"/>

<owl:ObjectProperty rdf:about="#hasOrigin">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Shipment"/>
  <rdfs:range rdf:resource="#Location"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasDestination">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Shipment"/>
  <rdfs:range rdf:resource="#Location"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#transportedBy">
  <rdfs:domain rdf:resource="#Shipment"/>
  <rdfs:range rdf:resource="#Vehicle"/>
  <owl:inverseOf rdf:resource="#transports"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#transports">
  <rdfs:domain rdf:resource="#Vehicle"/>
  <rdfs:range rdf:resource="#Shipment"/>
  <owl:inverseOf rdf:resource="#transportedBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#operatedBy">
  <rdfs:domain rdf:resource="#Vehicle"/>
  <rdfs:range rdf:resource="#Carrier"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#drivenBy">
  <rdfs:domain rdf:resource="#RoadVehicle"/>
  <rdfs:range rdf:resource="#Driver"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasRoute">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Shipment"/>
  <rdfs:range rdf:resource="#Route"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasSegment">
  <rdfs:domain rdf:resource="#Route"/>
  <rdfs:range rdf:resource="#RouteSegment"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#nextSegment">
  <rdfs:domain rdf:resource="#RouteSegment"/>
  <rdfs:range rdf:resource="#RouteSegment"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#usesMode">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#RouteSegment"/>
  <rdfs:range rdf:resource="#TransportMode"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#departsFrom">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#RouteSegment"/>
  <rdfs:range rdf:resource="#Location"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#arrivesAt">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#RouteSegment"/>
  <rdfs:range rdf:resource="#Location"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#shippedBy">
  <rdfs:domain rdf:resource="#Shipment"/>
  <rdfs:range rdf:resource="#Shipper"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#consignedTo">
  <rdfs:domain rdf:resource="#Shipment"/>
  <rdfs:range rdf:resource="#Consignee"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#handledBy">
  <rdfs:domain rdf:resource="#Shipment"/>
  <rdfs:range rdf:resource="#Agent"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#contains">
  <rdfs:domain rdf:resource="#Shipment"/>
  <rdfs:range rdf:resource="#Cargo"/>
  <owl:inverseOf rdf:resource="#partOfShipment"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#partOfShipment">
  <rdfs:domain rdf:resource="#Cargo"/>
  <rdfs:range rdf:resource="#Shipment"/>
  <owl:inverseOf rdf:resource="#contains"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#storedAt">
  <rdfs:domain rdf:resource="#Cargo"/>
  <rdfs:range rdf:resource="#Facility"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasStatus">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Shipment"/>
  <rdfs:range rdf:resource="#ShipmentStatus"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasEvent">
  <rdfs:domain rdf:resource="#Shipment"/>
  <rdfs:range rdf:resource="#TransportEvent"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#occursAt">
  <rdfs:domain rdf:resource="#TransportEvent"/>
  <rdfs:range rdf:resource="#Location"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#requiresDocument">
  <rdfs:domain rdf:resource="#Shipment"/>
  <rdfs:range rdf:resource="#LogisticsDocument"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#ownedBy">
  <rdfs:domain rdf:resource="#Vehicle"/>
  <rdfs:range rdf:resource="#Carrier"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#partOfOrder">
  <rdfs:domain rdf:resource="#Shipment"/>
  <rdfs:range rdf:resource="#Order"/>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#weightKg">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Shipment"/>
  <rdfs:domain rdf:resource="#Cargo"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#volumeM3">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Shipment"/>
  <rdfs:domain rdf:resource="#Cargo"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#capacityKg">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Vehicle"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#capacityM3">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Vehicle"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#maxSpeedKmH">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Vehicle"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#distanceKm">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#RouteSegment"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#estimatedTransitTimeHours">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Shipment"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#trackingNumber">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Shipment"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#requiredTemperatureC">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#PerishableShipment"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hazardClass">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#HazardousShipment"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#costUSD">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Shipment"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#isTemperatureControlled">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Vehicle"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#eventTimestamp">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#TransportEvent"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:Class rdf:about="#Agent">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Vehicle">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#capacityKg"/>
      <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
      <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#Location">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Facility">
  <rdfs:subClassOf rdf:resource="#Location"/>
</owl:Class>

<owl:Class rdf:about="#Shipment">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasOrigin"/>
      <owl:onClass rdf:resource="#Location"/>
      <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasDestination"/>
      <owl:onClass rdf:resource="#Location"/>
      <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#transportedBy"/>
      <owl:someValuesFrom rdf:resource="#Vehicle"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasStatus"/>
      <owl:onClass rdf:resource="#ShipmentStatus"/>
      <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#Cargo">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Route">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasSegment"/>
      <owl:onClass rdf:resource="#RouteSegment"/>
      <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#RouteSegment">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#TransportMode">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Order">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#TransportEvent">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#LogisticsDocument">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#ShipmentStatus">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Carrier">
  <rdfs:subClassOf rdf:resource="#Agent"/>
</owl:Class>

<owl:Class rdf:about="#Shipper">
  <rdfs:subClassOf rdf:resource="#Agent"/>
</owl:Class>

<owl:Class rdf:about="#Consignee">
  <rdfs:subClassOf rdf:resource="#Agent"/>
</owl:Class>

<owl:Class rdf:about="#Driver">
  <rdfs:subClassOf rdf:resource="#Agent"/>
</owl:Class>

<owl:Class rdf:about="#LogisticsServiceProvider">
  <rdfs:subClassOf rdf:resource="#Agent"/>
</owl:Class>

<owl:Class rdf:about="#RoadVehicle">
  <rdfs:subClassOf rdf:resource="#Vehicle"/>
</owl:Class>

<owl:Class rdf:about="#Truck">
  <rdfs:subClassOf rdf:resource="#RoadVehicle"/>
</owl:Class>

<owl:Class rdf:about="#Van">
  <rdfs:subClassOf rdf:resource="#RoadVehicle"/>
</owl:Class>

<owl:Class rdf:about="#Ship">
  <rdfs:subClassOf rdf:resource="#Vehicle"/>
</owl:Class>

<owl:Class rdf:about="#Aircraft">
  <rdfs:subClassOf rdf:resource="#Vehicle"/>
</owl:Class>

<owl:Class rdf:about="#Train">
  <rdfs:subClassOf rdf:resource="#Vehicle"/>
</owl:Class>

<owl:Class rdf:about="#Drone">
  <rdfs:subClassOf rdf:resource="#Vehicle"/>
</owl:Class>

<owl:Class rdf:about="#Warehouse">
  <rdfs:subClassOf rdf:resource="#Facility"/>
</owl:Class>

<owl:Class rdf:about="#DistributionCenter">
  <rdfs:subClassOf rdf:resource="#Facility"/>
</owl:Class>

<owl:Class rdf:about="#Port">
  <rdfs:subClassOf rdf:resource="#Facility"/>
</owl:Class>

<owl:Class rdf:about="#Airport">
  <rdfs:subClassOf rdf:resource="#Facility"/>
</owl:Class>

<owl:Class rdf:about="#RailTerminal">
  <rdfs:subClassOf rdf:resource="#Facility"/>
</owl:Class>

<owl:Class rdf:about="#CustomerAddress">
  <rdfs:subClassOf rdf:resource="#Location"/>
</owl:Class>

<owl:Class rdf:about="#Package">
  <rdfs:subClassOf rdf:resource="#Cargo"/>
</owl:Class>

<owl:Class rdf:about="#Container">
  <rdfs:subClassOf rdf:resource="#Cargo"/>
</owl:Class>

<owl:Class rdf:about="#Pallet">
  <rdfs:subClassOf rdf:resource="#Cargo"/>
</owl:Class>

<owl:Class rdf:about="#PerishableShipment">
  <rdfs:subClassOf rdf:resource="#Shipment"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#requiredTemperatureC"/>
      <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
      <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#HazardousShipment">
  <rdfs:subClassOf rdf:resource="#Shipment"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hazardClass"/>
      <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
      <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#OversizedShipment">
  <rdfs:subClassOf rdf:resource="#Shipment"/>
</owl:Class>

<owl:Class rdf:about="#OverloadedShipment">
  <rdfs:subClassOf rdf:resource="#Shipment"/>
</owl:Class>

<owl:Class rdf:about="#RestrictedShipment">
  <rdfs:subClassOf rdf:resource="#Shipment"/>
</owl:Class>

<owl:Class rdf:about="#AtRiskShipment">
  <rdfs:subClassOf rdf:resource="#Shipment"/>
</owl:Class>

<owl:Class rdf:about="#DelayedShipment">
  <rdfs:subClassOf rdf:resource="#Shipment"/>
</owl:Class>

<owl:Class rdf:about="#PickupEvent">
  <rdfs:subClassOf rdf:resource="#TransportEvent"/>
</owl:Class>

<owl:Class rdf:about="#DeliveryEvent">
  <rdfs:subClassOf rdf:resource="#TransportEvent"/>
</owl:Class>

<owl:Class rdf:about="#DelayEvent">
  <rdfs:subClassOf rdf:resource="#TransportEvent"/>
</owl:Class>

<owl:Class rdf:about="#CustomsClearanceEvent">
  <rdfs:subClassOf rdf:resource="#TransportEvent"/>
</owl:Class>

<owl:Class rdf:about="#TransshipmentEvent">
  <rdfs:subClassOf rdf:resource="#TransportEvent"/>
</owl:Class>

<owl:Class rdf:about="#BillOfLading">
  <rdfs:subClassOf rdf:resource="#LogisticsDocument"/>
</owl:Class>

<owl:Class rdf:about="#Invoice">
  <rdfs:subClassOf rdf:resource="#LogisticsDocument"/>
</owl:Class>

<owl:Class rdf:about="#CustomsDeclaration">
  <rdfs:subClassOf rdf:resource="#LogisticsDocument"/>
</owl:Class>

<owl:Class rdf:about="#ProofOfDelivery">
  <rdfs:subClassOf rdf:resource="#LogisticsDocument"/>
</owl:Class>

<owl:NamedIndividual rdf:about="#RoadMode">
  <rdf:type rdf:resource="#TransportMode"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#RailMode">
  <rdf:type rdf:resource="#TransportMode"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#SeaMode">
  <rdf:type rdf:resource="#TransportMode"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#AirMode">
  <rdf:type rdf:resource="#TransportMode"/>
</owl:NamedIndividual>

